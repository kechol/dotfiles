# This is the configuration file for Ghostty.
# https://ghostty.org/docs/config
#
# /Users/kechol/Library/Application Support/com.mitchellh.ghostty/config

theme = Xcode Dark hc
background-opacity = 0.8
background-blur-radius = 20

window-padding-x = 4
window-padding-y = 4
window-padding-balance = true

font-family = Hackmen
font-size = 13
adjust-cell-height = 8%

cursor-style = block
clipboard-read = allow
clipboard-write = allow

macos-titlebar-style = transparent

keybind = cmd+w=close_surface
keybind = cmd+ctrl+h=goto_split:left
keybind = cmd+ctrl+j=goto_split:down
keybind = cmd+ctrl+k=goto_split:up
keybind = cmd+ctrl+l=goto_split:right
keybind = cmd+ctrl+;=toggle_quick_terminal